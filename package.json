{
  "name": "nama-medical-web",
  "version": "2.0.0",
  "description": "Nama Medical ERP - Web Application (Modular Architecture)",
  "main": "server_modular.js",
  "scripts": {
    "start": "node server_modular.js",
    "dev": "node server_modular.js",
    "legacy": "node server.js",
    "test": "jest --runInBand --verbose",
    "test:ci": "jest --runInBand --forceExit --ci",
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "setup": "setup.bat",
    "postinstall": "node -e \"const fs=require('fs');if(!fs.existsSync('.env')&&fs.existsSync('.env.example')){fs.copyFileSync('.env.example','.env');console.log('✅ Created .env from .env.example')}\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "pg": "^8.18.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
